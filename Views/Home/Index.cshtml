@model SalesforceManager.Models.HomeViewModel
@{
    ViewData["Title"] = "Home Page";
}

<style>
    .table-cell-truncate {
        max-width: 200px;
    }
    .table-cell-truncate > span {
        display: block;
        width: 100%;
        overflow: hidden;
        white-space: nowrap;
        text-overflow: ellipsis;
    }
    .user-role-filter-menu {
        max-height: 16rem;
        overflow-y: auto;
        min-width: 100%;
    }
</style>


<h2>Salesforce Users</h2>
@if (!string.IsNullOrWhiteSpace(ViewBag.ErrorMessage))
{
    <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
}



@if (Model == null || Model.Users.Count == 0)
{
    <p>No users found.</p>
}
else
{
    <form id="userSearchForm" class="mb-3">
        <div class="row">
            <div class="col-12 col-md-6">
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="bi bi-search" aria-hidden="true"></i>
                    </span>
                    <input
                        id="userSearchInput"
                        type="search"
                        class="form-control"
                        placeholder="Search by name or username"
                        aria-label="Search users by name or username" />
                    <button id="userSearchButton" type="submit" class="btn btn-primary">Search</button>
                </div>
            </div>
            <div class="col-12 col-md-2">
                <select id="userLastLoginSelect" class="form-select" aria-label="Filter by last login">
                    <option value="" selected>All last logins</option>
                    <option value="within-1d">Last 24 hours</option>
                    <option value="within-7d">Last 7 days</option>
                    <option value="within-30d">Last 30 days</option>
                    <option value="older-30d">> 30 days ago</option>
                    <option value="older-90d">> 90 days ago</option>
                </select>
            </div>
            <div class="col-12 col-md-2">
                <label id="userRoleFilterLabel" class="form-label visually-hidden">Filter by role</label>
                <div id="userRoleFilterDropdown" class="dropdown w-100">
                    <button
                        type="button"
                        class="btn btn-outline-secondary dropdown-toggle w-100 text-start d-flex justify-content-between align-items-center gap-1"
                        id="userRoleFilterToggle"
                        data-bs-toggle="dropdown"
                        aria-expanded="false"
                        aria-haspopup="true"
                        aria-controls="userRoleFilterMenu"
                        aria-labelledby="userRoleFilterLabel userRoleFilterToggle">
                        <span class="text-truncate flex-grow-1 js-user-role-filter-summary">All roles</span>
                    </button>
                    <div
                        class="dropdown-menu user-role-filter-menu p-2"
                        id="userRoleFilterMenu"
                        aria-labelledby="userRoleFilterToggle">
                        <div class="form-check">
                            <input class="form-check-input js-role-filter-all" type="checkbox" id="userRoleFilterAll" checked />
                            <label class="form-check-label" for="userRoleFilterAll">All roles</label>
                        </div>
                        <hr class="dropdown-divider my-1" />
                        @{ var roleFilterIndex = 0; }
                        @foreach (var role in Model.Roles)
                        {
                            var roleCbId = $"userRoleFilterRole{roleFilterIndex}";
                            roleFilterIndex++;
                            <div class="form-check">
                                <input
                                    class="form-check-input js-role-filter-role"
                                    type="checkbox"
                                    value="@role.Id"
                                    id="@roleCbId"
                                    data-role-name="@role.Name" />
                                <label class="form-check-label text-truncate d-block" for="@roleCbId" title="@role.Name">@role.Name</label>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-2">
                <select id="userStatusSelect" class="form-select">
                    <option value="" selected>All statuses</option>
                    <option value="active">Active</option>
                    <option value="inactive">Inactive</option>
                </select>
            </div>
        </div>
    </form>
    <table class="table">
        <thead>
            <tr>
                <th>
                    <button type="button" class="btn btn-link p-0 text-decoration-none text-nowrap js-user-sort" data-sort-by="name">
                        Name <span class="js-sort-indicator" aria-hidden="true"></span>
                    </button>
                </th>
                <th>
                    <button type="button" class="btn btn-link p-0 text-decoration-none text-nowrap js-user-sort" data-sort-by="username">
                        Username <span class="js-sort-indicator" aria-hidden="true"></span>
                    </button>
                </th>
                <th>
                    <button type="button" class="btn btn-link p-0 text-decoration-none text-nowrap js-user-sort" data-sort-by="lastlogindate">
                        Last Login <span class="js-sort-indicator" aria-hidden="true"></span>
                    </button>
                </th>
                <th>
                    <button type="button" class="btn btn-link p-0 text-decoration-none text-nowrap js-user-sort" data-sort-by="role">
                        Role <span class="js-sort-indicator" aria-hidden="true"></span>
                    </button>
                </th>
                <th>
                    <button type="button" class="btn btn-link p-0 text-decoration-none text-nowrap js-user-sort" data-sort-by="active">
                        Active <span class="js-sort-indicator" aria-hidden="true"></span>
                    </button>
                </th>
            </tr>
        </thead>
        <tbody id="salesforceUsersTableBody">
        @foreach (var user in Model.Users)
        {
            <tr>
                <td class="text-nowrap">@user.Name</td>
                <td class="table-cell-truncate">
                    <span title="@user.Username">@user.Username</span>
                </td>
                <td class="text-nowrap">@user.LastLoginDate</td>
                <td class="text-nowrap">@user.UserRoleId</td>
                <td>
                    <input
                        type="checkbox"
                        class="js-user-active"
                        data-user-id="@user.Id"
                        data-user-name="@user.Name"
                        @(user.IsActive ? "checked" : "") />
                </td>
            </tr>
        }
        </tbody>
    </table>
}

<div class="modal fade" id="userActiveConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm status change</h5>
            </div>
            <div class="modal-body">
                <p id="userActiveConfirmMessage" class="mb-0"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmUserActiveChangeBtn">Confirm</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="userActiveErrorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Update failed</h5>
            </div>
            <div class="modal-body">
                <p id="userActiveErrorMessage" class="mb-0"></p>
                <p id="userActiveErrorDetail" 
                    class="mb-0" 
                    style="
                        font-family:Consolas,'Courier New',monospace;
                        font-size:10px;
                        white-space:pre-wrap;
                        padding:8px;
                        margin-top:8px;
                        margin-bottom:0;
                        border-radius:4px;
                        ">
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const tableBody = document.getElementById("salesforceUsersTableBody");
        const sortButtons = document.querySelectorAll(".js-user-sort");
        const userSearchForm = document.getElementById("userSearchForm");
        const userSearchInput = document.getElementById("userSearchInput");
        const userSearchButton = document.getElementById("userSearchButton");
        const userRoleFilterDropdown = document.getElementById("userRoleFilterDropdown");
        const userRoleFilterToggle = document.getElementById("userRoleFilterToggle");
        const userRoleFilterMenu = document.getElementById("userRoleFilterMenu");
        const userRoleFilterAll = document.getElementById("userRoleFilterAll");
        const userRoleFilterSummary = document.querySelector(".js-user-role-filter-summary");
        const userStatusSelect = document.getElementById("userStatusSelect");
        const userLastLoginSelect = document.getElementById("userLastLoginSelect");

        function getUserRoleFilterDisableTargets() {
            if (!userRoleFilterDropdown || !userRoleFilterToggle) {
                return [];
            }

            return [userRoleFilterToggle].concat(
                Array.from(userRoleFilterDropdown.querySelectorAll("input[type='checkbox']"))
            );
        }

        const confirmModalElement = document.getElementById("userActiveConfirmModal");
        const confirmMessageElement = document.getElementById("userActiveConfirmMessage");
        const confirmButton = document.getElementById("confirmUserActiveChangeBtn");
        const errorModalElement = document.getElementById("userActiveErrorModal");
        const errorMessageElement = document.getElementById("userActiveErrorMessage");
        const errorDetailElement = document.getElementById("userActiveErrorDetail");
        const canUseBootstrapModal = typeof window.bootstrap !== "undefined" && confirmModalElement;
        const confirmModal = canUseBootstrapModal ? new window.bootstrap.Modal(confirmModalElement) : null;
        const errorModal = canUseBootstrapModal && errorModalElement ? new window.bootstrap.Modal(errorModalElement) : null;
        
        let pendingChange = null;
        let currentSortBy = null;
        let currentSortDirection = "asc";
        let currentSearch = "";

        function readUserProperty(user, camelCaseName, pascalCaseName) {
            return user[camelCaseName] ?? user[pascalCaseName] ?? "";
        }

        function createTextCell(value, options = {}) {
            const cell = document.createElement("td");
            if (options.truncate) {
                const span = document.createElement("span");
                cell.classList.add("table-cell-truncate");
                span.textContent = value;
                span.title = value;
                cell.appendChild(span);
                return cell;
            }
            cell.classList.add("text-nowrap");
            cell.textContent = value;
            return cell;
        }

        function createActiveCell(user) {
            const userId = readUserProperty(user, "id", "Id");
            const userName = readUserProperty(user, "name", "Name");
            const isActive = Boolean(user.isActive ?? user.IsActive);
            const cell = document.createElement("td");
            const checkbox = document.createElement("input");

            checkbox.type = "checkbox";
            checkbox.className = "js-user-active";
            checkbox.dataset.userId = userId;
            checkbox.dataset.userName = userName;
            checkbox.checked = isActive;
            cell.appendChild(checkbox);

            return cell;
        }

        function renderUsers(users) {
            if (!tableBody) {
                return;
            }

            tableBody.innerHTML = "";
            users.forEach(function (user) {
                const row = document.createElement("tr");
                row.appendChild(createTextCell(readUserProperty(user, "name", "Name")));
                row.appendChild(createTextCell(readUserProperty(user, "username", "Username"),  { truncate: true }));
                row.appendChild(createTextCell(readUserProperty(user, "lastLoginDate", "LastLoginDate")));
                row.appendChild(createTextCell(readUserProperty(user, "userRoleId", "UserRoleId")));
                row.appendChild(createActiveCell(user));
                tableBody.appendChild(row);
            });
        }

        function showError(message, detail) {
            if (errorMessageElement) {
                errorMessageElement.textContent = message;
            }

            if (errorDetailElement) {
                errorDetailElement.textContent = detail || "";
            }

            if (errorModal) {
                errorModal.show();
                return;
            }

            window.alert(detail ? `${message}: ${detail}` : message);
        }

        async function readProblemDetail(response) {
            const text = await response.text();
            if (!text) {
                return response.statusText;
            }

            try {
                const errorBody = JSON.parse(text);
                return errorBody.detail || text;
            } catch {
                return text;
            }
        }

        function setSortButtonState() {
            sortButtons.forEach(function (button) {
                const sortBy = button.dataset.sortBy || null;
                const isActiveSort = sortBy === currentSortBy;
                const indicator = button.querySelector(".js-sort-indicator");
                button.setAttribute("aria-pressed", isActiveSort ? "true" : "false");

                if (indicator) {
                    indicator.innerHTML = isActiveSort
                        ? (currentSortDirection === "asc"
                            ? '<i class="bi bi-sort-up-alt"></i>'
                            : '<i class="bi bi-sort-down"></i>')
                        : "";
                }
            });
        }

        function setControlsDisabled(disabled, controls) {
            controls = [
                sortButtons, 
                userSearchInput, 
                userSearchButton, 
                userStatusSelect,
                userLastLoginSelect
            ].concat(getUserRoleFilterDisableTargets());
            controls.forEach(function (control) {
                if (control instanceof HTMLInputElement || control instanceof HTMLButtonElement || control instanceof HTMLSelectElement) {
                    control.disabled = disabled;
                    return;
                }

                if (control && typeof control.forEach === "function") {
                    control.forEach(function (nestedControl) {
                        if (nestedControl instanceof HTMLButtonElement) {
                            nestedControl.disabled = disabled;
                        }
                    });
                }
            });
        }

        function getSelectedRoleIds() {
            if (!userRoleFilterDropdown) {
                return [];
            }

            return Array.from(userRoleFilterDropdown.querySelectorAll(".js-role-filter-role:checked"))
                .map(function (input) {
                    return input.value;
                })
                .filter(function (value) {
                    return value !== "";
                });
        }

        function updateUserRoleFilterSummary() {
            if (!(userRoleFilterSummary instanceof HTMLElement)) {
                return;
            }
            const checkedRoles = Array.from(
                (userRoleFilterDropdown || document).querySelectorAll(".js-role-filter-role:checked")
            );
            if (checkedRoles.length === 0) {
                userRoleFilterSummary.textContent = "All roles";
                return;
            }
            if (checkedRoles.length === 1) {
                const name = checkedRoles[0].dataset.roleName || checkedRoles[0].value;
                userRoleFilterSummary.textContent = name;
                return;
            }
            const firstName = checkedRoles[0].dataset.roleName || checkedRoles[0].value;
            userRoleFilterSummary.textContent = `${firstName} +${checkedRoles.length - 1}`;
        }

        function syncUserRoleFilterAllState() {
            if (!(userRoleFilterAll instanceof HTMLInputElement) || !userRoleFilterDropdown) {
                return;
            }
            const anyRoleChecked = userRoleFilterDropdown.querySelector(".js-role-filter-role:checked");
            userRoleFilterAll.checked = !anyRoleChecked;
            updateUserRoleFilterSummary();
        }

        function buildUsersQuery(
            sortBy, 
            sortDirection, 
            search,
            roleIds,
            status,
            lastLogin
        ) {
            const query = new URLSearchParams();

            if (sortDirection) {
                query.append("sortDirection", sortDirection);
            }
            if (sortBy) {
                query.append("sortBy", sortBy);
            }
            if (search) {
                query.append("search", search);
            }
            if (roleIds && roleIds.length > 0) {
                roleIds.forEach(function (id) {
                    query.append("roleId", id);
                });
            }
            if (status) {
                query.append("status", status);
            }
            if (lastLogin) {
                query.append("lastLogin", lastLogin);
            }

            return query;
        }

        async function sortUsers(sortBy) {
            const nextDirection = currentSortBy === sortBy && currentSortDirection === "asc"
                ? "desc"
                : "asc";
            const query = buildUsersQuery(
                sortBy, 
                nextDirection, 
                currentSearch, 
                getSelectedRoleIds(), 
                userStatusSelect.value,
                userLastLoginSelect.value
            );
            // console.log(query.toString());

            setControlsDisabled(true);

            try {
                const response = await fetch(`/api/sf/users?${query.toString()}`);
                if (!response.ok) {
                    throw new Error(await readProblemDetail(response));
                }

                renderUsers(await response.json());
                currentSortBy = sortBy;
                currentSortDirection = nextDirection;
                setSortButtonState();
            } catch (error) {
                showError("Unable to sort users", error.message);
            } finally {
                setControlsDisabled(false);
            }
        }

        async function searchUsers(searchText) {
            const normalizedSearch = (searchText || "").trim();
            const query = buildUsersQuery(
                currentSortBy, 
                currentSortDirection, 
                normalizedSearch, 
                getSelectedRoleIds(), 
                userStatusSelect.value,
                userLastLoginSelect.value
            );
            setControlsDisabled(true);

            try {
                const response = await fetch(`/api/sf/users?${query.toString()}`);
                if (!response.ok) {
                    throw new Error(await readProblemDetail(response));
                }

                renderUsers(await response.json());
                currentSearch = normalizedSearch;
                setSortButtonState();
            } catch (error) {
                showError("Unable to search users", error.message);
            } finally {
                setControlsDisabled(false);
            }
        }

        async function filterUsers() {
            const query = buildUsersQuery(
                currentSortBy,
                currentSortDirection,
                currentSearch,
                getSelectedRoleIds(),
                userStatusSelect.value,
                userLastLoginSelect.value
            );
            setControlsDisabled(true);

            try {
                const response = await fetch(`/api/sf/users?${query.toString()}`);
                if (!response.ok) {
                    throw new Error(await readProblemDetail(response));
                }

                renderUsers(await response.json());
                setSortButtonState();
            } catch (error) {
                showError("Unable to filter users", error.message);
            } finally {
                setControlsDisabled(false);
            }
        }

        async function submitUserActiveChange(checkbox, userId) {
            const previousChecked = !checkbox.checked;
            checkbox.disabled = true;

            try {
                const response = await fetch(`/api/sf/users/${encodeURIComponent(userId)}/active`, {
                    method: "PATCH",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({
                        inactive: !checkbox.checked
                    })
                });

                if (!response.ok) {
                    throw new Error(await readProblemDetail(response));
                }
            } catch (error) {
                checkbox.checked = previousChecked;
                const message = `Unable to ${checkbox.checked ? "deactivate" : "activate"} user`;
                showError(message, error.message);
            } finally {
                checkbox.disabled = false;
            }
        }

        sortButtons.forEach(function (button) {
            button.addEventListener("click", function () {
                sortUsers(button.dataset.sortBy || null);
            });
        });

        if (userSearchForm instanceof HTMLFormElement && userSearchInput instanceof HTMLInputElement) {
            userSearchForm.addEventListener("submit", function (event) {
                event.preventDefault();
                searchUsers(userSearchInput.value);
            });
            userSearchInput.addEventListener("search", function () {
                if (userSearchInput.value.trim() === "" && currentSearch !== "") {
                    searchUsers("");
                }
            });
            userSearchInput.addEventListener("input", function () {
                if (userSearchInput.value.trim() === "" && currentSearch !== "") {
                    searchUsers("");
                }
            });
        }

        if (userRoleFilterMenu instanceof HTMLElement) {
            userRoleFilterMenu.addEventListener("mousedown", function (event) {
                event.stopPropagation();
            });
        }

        if (userRoleFilterDropdown && userRoleFilterAll instanceof HTMLInputElement) {
            userRoleFilterDropdown.addEventListener("change", function (event) {
                const target = event.target;
                if (!(target instanceof HTMLInputElement)) {
                    return;
                }

                if (target.classList.contains("js-role-filter-all")) {
                    if (target.checked) {
                        userRoleFilterDropdown.querySelectorAll(".js-role-filter-role").forEach(function (cb) {
                            if (cb instanceof HTMLInputElement) {
                                cb.checked = false;
                            }
                        });
                    } else {
                        const anyRole = userRoleFilterDropdown.querySelector(".js-role-filter-role:checked");
                        if (!anyRole) {
                            target.checked = true;
                            return;
                        }
                    }

                    updateUserRoleFilterSummary();
                    filterUsers();
                    return;
                }

                if (target.classList.contains("js-role-filter-role")) {
                    if (target.checked) {
                        userRoleFilterAll.checked = false;
                    }

                    syncUserRoleFilterAllState();
                    filterUsers();
                }
            });
        }

        if (userStatusSelect instanceof HTMLSelectElement) {
            userStatusSelect.addEventListener("change", function () {
                filterUsers();
            });
        }

        if (userLastLoginSelect instanceof HTMLSelectElement) {
            userLastLoginSelect.addEventListener("change", function () {
                filterUsers();
            });
        }

        setSortButtonState();

        document.addEventListener("change", function (event) {
            const checkbox = event.target;
            if (!(checkbox instanceof HTMLInputElement) || !checkbox.classList.contains("js-user-active")) {
                return;
            }

            const userId = checkbox.dataset.userId;
            if (!userId) {
                return;
            }

            if (!confirmModal || !confirmMessageElement || !confirmButton) {
                submitUserActiveChange(checkbox, userId);
                return;
            }

            const previousChecked = !checkbox.checked;
            const actionText = checkbox.checked ? "activate" : "deactivate";
            const userName = checkbox.dataset.userName || "this user";
            confirmMessageElement.innerHTML = `Are you sure you want to <strong>${actionText}</strong> <u>${userName}</u>?`;
            pendingChange = { checkbox, userId, previousChecked };
            confirmModal.show();
        });

        if (confirmModalElement) {
            confirmModalElement.addEventListener("hidden.bs.modal", function () {
                if (!pendingChange) {
                    return;
                }

                pendingChange.checkbox.checked = pendingChange.previousChecked;
                pendingChange = null;
            });
        }

        if (confirmButton) {
            confirmButton.addEventListener("click", async function () {
                if (!pendingChange) {
                    return;
                }

                const currentChange = pendingChange;
                pendingChange = null;
                confirmModal.hide();
                await submitUserActiveChange(currentChange.checkbox, currentChange.userId);
            });
        }
    });
</script>
