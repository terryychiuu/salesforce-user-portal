@model SalesforceManager.Models.HomeViewModel
@{
    ViewData["Title"] = "Home Page";
}


<h2>Salesforce Users</h2>
@if (!string.IsNullOrWhiteSpace(ViewBag.ErrorMessage))
{
    <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
}



@if (Model == null || Model.Users.Count == 0)
{
    <p>No users found.</p>
}
else
{
    <form id="userSearchForm" class="mb-3">
        <div class="row">
            <div class="col-12 col-md-8">
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="bi bi-search" aria-hidden="true"></i>
                    </span>
                    <input
                        id="userSearchInput"
                        type="search"
                        class="form-control"
                        placeholder="Search by name or username"
                        aria-label="Search users by name or username" />
                    <button id="userSearchButton" type="submit" class="btn btn-primary">Search</button>
                </div>
            </div>
            <div class="col-12 col-md-2">
                <select id="userRoleSelect" class="form-select">
                    <option value="" selected>All roles</option>
                    @foreach (var role in Model.Roles)
                    {
                        <option value="@role.Id">@role.Name</option>
                    }
                </select>
            </div>
            <div class="col-12 col-md-2">
                <select id="userStatusSelect" class="form-select">
                    <option value="" selected>All statuses</option>
                    <option value="active">Active</option>
                    <option value="inactive">Inactive</option>
                </select>
            </div>
        </div>
    </form>
    <table class="table">
        <thead>
            <tr>
                <th>
                    <button type="button" class="btn btn-link p-0 text-decoration-none text-nowrap js-user-sort" data-sort-by="name">
                        Name <span class="js-sort-indicator" aria-hidden="true"></span>
                    </button>
                </th>
                <th>
                    <button type="button" class="btn btn-link p-0 text-decoration-none text-nowrap js-user-sort" data-sort-by="username">
                        Username <span class="js-sort-indicator" aria-hidden="true"></span>
                    </button>
                </th>
                <th>
                    <button type="button" class="btn btn-link p-0 text-decoration-none text-nowrap js-user-sort" data-sort-by="lastlogindate">
                        Last Login <span class="js-sort-indicator" aria-hidden="true"></span>
                    </button>
                </th>
                <th>
                    <button type="button" class="btn btn-link p-0 text-decoration-none text-nowrap js-user-sort" data-sort-by="role">
                        Role <span class="js-sort-indicator" aria-hidden="true"></span>
                    </button>
                </th>
                <th>
                    <button type="button" class="btn btn-link p-0 text-decoration-none text-nowrap js-user-sort" data-sort-by="active">
                        Active <span class="js-sort-indicator" aria-hidden="true"></span>
                    </button>
                </th>
            </tr>
        </thead>
        <tbody id="salesforceUsersTableBody">
        @foreach (var user in Model.Users)
        {
            <tr>
                <td class="text-nowrap">@user.Name</td>
                <td class="text-nowrap">@user.Username</td>
                <td class="text-nowrap">@user.LastLoginDate</td>
                <td class="text-nowrap">@user.UserRoleId</td>
                <td>
                    <input
                        type="checkbox"
                        class="js-user-active"
                        data-user-id="@user.Id"
                        data-user-name="@user.Name"
                        @(user.IsActive ? "checked" : "") />
                </td>
            </tr>
        }
        </tbody>
    </table>
}

<div class="modal fade" id="userActiveConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm status change</h5>
            </div>
            <div class="modal-body">
                <p id="userActiveConfirmMessage" class="mb-0"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmUserActiveChangeBtn">Confirm</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="userActiveErrorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Update failed</h5>
            </div>
            <div class="modal-body">
                <p id="userActiveErrorMessage" class="mb-0"></p>
                <p id="userActiveErrorDetail" 
                    class="mb-0" 
                    style="
                        font-family:Consolas,'Courier New',monospace;
                        font-size:10px;
                        white-space:pre-wrap;
                        padding:8px;
                        margin-top:8px;
                        margin-bottom:0;
                        border-radius:4px;
                        ">
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const tableBody = document.getElementById("salesforceUsersTableBody");
        const sortButtons = document.querySelectorAll(".js-user-sort");
        const userSearchForm = document.getElementById("userSearchForm");
        const userSearchInput = document.getElementById("userSearchInput");
        const userSearchButton = document.getElementById("userSearchButton");
        const userRoleSelect = document.getElementById("userRoleSelect");
        const userStatusSelect = document.getElementById("userStatusSelect");

        const confirmModalElement = document.getElementById("userActiveConfirmModal");
        const confirmMessageElement = document.getElementById("userActiveConfirmMessage");
        const confirmButton = document.getElementById("confirmUserActiveChangeBtn");
        const errorModalElement = document.getElementById("userActiveErrorModal");
        const errorMessageElement = document.getElementById("userActiveErrorMessage");
        const errorDetailElement = document.getElementById("userActiveErrorDetail");
        const canUseBootstrapModal = typeof window.bootstrap !== "undefined" && confirmModalElement;
        const confirmModal = canUseBootstrapModal ? new window.bootstrap.Modal(confirmModalElement) : null;
        const errorModal = canUseBootstrapModal && errorModalElement ? new window.bootstrap.Modal(errorModalElement) : null;
        
        let pendingChange = null;
        let currentSortBy = null;
        let currentSortDirection = "asc";
        let currentSearch = "";

        function readUserProperty(user, camelCaseName, pascalCaseName) {
            return user[camelCaseName] ?? user[pascalCaseName] ?? "";
        }

        function createTextCell(value) {
            const cell = document.createElement("td");
            cell.classList.add("text-nowrap");
            cell.textContent = value;
            return cell;
        }

        function createActiveCell(user) {
            const userId = readUserProperty(user, "id", "Id");
            const userName = readUserProperty(user, "name", "Name");
            const isActive = Boolean(user.isActive ?? user.IsActive);
            const cell = document.createElement("td");
            const checkbox = document.createElement("input");

            checkbox.type = "checkbox";
            checkbox.className = "js-user-active";
            checkbox.dataset.userId = userId;
            checkbox.dataset.userName = userName;
            checkbox.checked = isActive;
            cell.appendChild(checkbox);

            return cell;
        }

        function renderUsers(users) {
            if (!tableBody) {
                return;
            }

            tableBody.innerHTML = "";
            users.forEach(function (user) {
                const row = document.createElement("tr");
                row.appendChild(createTextCell(readUserProperty(user, "name", "Name")));
                row.appendChild(createTextCell(readUserProperty(user, "username", "Username")));
                row.appendChild(createTextCell(readUserProperty(user, "lastLoginDate", "LastLoginDate")));
                row.appendChild(createTextCell(readUserProperty(user, "userRoleId", "UserRoleId")));
                row.appendChild(createActiveCell(user));
                tableBody.appendChild(row);
            });
        }

        function showError(message, detail) {
            if (errorMessageElement) {
                errorMessageElement.textContent = message;
            }

            if (errorDetailElement) {
                errorDetailElement.textContent = detail || "";
            }

            if (errorModal) {
                errorModal.show();
                return;
            }

            window.alert(detail ? `${message}: ${detail}` : message);
        }

        async function readProblemDetail(response) {
            const text = await response.text();
            if (!text) {
                return response.statusText;
            }

            try {
                const errorBody = JSON.parse(text);
                return errorBody.detail || text;
            } catch {
                return text;
            }
        }

        function setSortButtonState() {
            sortButtons.forEach(function (button) {
                const sortBy = button.dataset.sortBy || null;
                const isActiveSort = sortBy === currentSortBy;
                const indicator = button.querySelector(".js-sort-indicator");
                button.setAttribute("aria-pressed", isActiveSort ? "true" : "false");

                if (indicator) {
                    indicator.innerHTML = isActiveSort
                        ? (currentSortDirection === "asc"
                            ? '<i class="bi bi-sort-up-alt"></i>'
                            : '<i class="bi bi-sort-down"></i>')
                        : "";
                }
            });
        }

        function setControlsDisabled(disabled, controls) {
            controls.forEach(function (control) {
                if (control instanceof HTMLInputElement || control instanceof HTMLButtonElement || control instanceof HTMLSelectElement) {
                    control.disabled = disabled;
                    return;
                }

                if (control && typeof control.forEach === "function") {
                    control.forEach(function (nestedControl) {
                        if (nestedControl instanceof HTMLButtonElement) {
                            nestedControl.disabled = disabled;
                        }
                    });
                }
            });
        }

        function buildUsersQuery(
            sortBy, 
            sortDirection, 
            search,
            roleId,
            status
        ) {
            const query = new URLSearchParams();

            if (sortDirection) {
                query.append("sortDirection", sortDirection);
            }
            if (sortBy) {
                query.append("sortBy", sortBy);
            }
            if (search) {
                query.append("search", search);
            }
            if (roleId) {
                query.append("roleId", roleId);
            }
            if (status) {
                query.append("status", status);
            }

            return query;
        }

        async function sortUsers(sortBy) {
            const nextDirection = currentSortBy === sortBy && currentSortDirection === "asc"
                ? "desc"
                : "asc";
            const query = buildUsersQuery(
                sortBy, 
                nextDirection, 
                currentSearch, 
                userRoleSelect.value, 
                userStatusSelect.value
            );
            // console.log(query.toString());

            setControlsDisabled(true, [sortButtons, userSearchInput, userSearchButton, userRoleSelect, userStatusSelect]);

            try {
                const response = await fetch(`/api/sf/users?${query.toString()}`);
                if (!response.ok) {
                    throw new Error(await readProblemDetail(response));
                }

                renderUsers(await response.json());
                currentSortBy = sortBy;
                currentSortDirection = nextDirection;
                setSortButtonState();
            } catch (error) {
                showError("Unable to sort users", error.message);
            } finally {
                setControlsDisabled(false, [sortButtons, userSearchInput, userSearchButton, userRoleSelect, userStatusSelect]);
            }
        }

        async function searchUsers(searchText) {
            const normalizedSearch = (searchText || "").trim();
            const query = buildUsersQuery(
                currentSortBy, 
                currentSortDirection, 
                normalizedSearch, 
                userRoleSelect.value, 
                userStatusSelect.value
            );
            setControlsDisabled(true, [sortButtons, userSearchInput, userSearchButton]);

            try {
                const response = await fetch(`/api/sf/users?${query.toString()}`);
                if (!response.ok) {
                    throw new Error(await readProblemDetail(response));
                }

                renderUsers(await response.json());
                currentSearch = normalizedSearch;
                setSortButtonState();
            } catch (error) {
                showError("Unable to search users", error.message);
            } finally {
                setControlsDisabled(false, [sortButtons, userSearchInput, userSearchButton]);
            }
        }

        async function filterUsers() {
            const query = buildUsersQuery(
                currentSortBy,
                currentSortDirection,
                currentSearch,
                userRoleSelect.value,
                userStatusSelect.value
            );
            setControlsDisabled(true, [sortButtons, userSearchInput, userSearchButton, userRoleSelect, userStatusSelect]);

            try {
                const response = await fetch(`/api/sf/users?${query.toString()}`);
                if (!response.ok) {
                    throw new Error(await readProblemDetail(response));
                }

                renderUsers(await response.json());
                setSortButtonState();
            } catch (error) {
                showError("Unable to filter users", error.message);
            } finally {
                setControlsDisabled(false, [sortButtons, userSearchInput, userSearchButton, userRoleSelect, userStatusSelect]);
            }
        }

        async function submitUserActiveChange(checkbox, userId) {
            const previousChecked = !checkbox.checked;
            checkbox.disabled = true;

            try {
                const response = await fetch(`/api/sf/users/${encodeURIComponent(userId)}/active`, {
                    method: "PATCH",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({
                        inactive: !checkbox.checked
                    })
                });

                if (!response.ok) {
                    throw new Error(await readProblemDetail(response));
                }
            } catch (error) {
                checkbox.checked = previousChecked;
                const message = `Unable to ${checkbox.checked ? "deactivate" : "activate"} user`;
                showError(message, error.message);
            } finally {
                checkbox.disabled = false;
            }
        }

        sortButtons.forEach(function (button) {
            button.addEventListener("click", function () {
                sortUsers(button.dataset.sortBy || null);
            });
        });

        if (userSearchForm instanceof HTMLFormElement && userSearchInput instanceof HTMLInputElement) {
            userSearchForm.addEventListener("submit", function (event) {
                event.preventDefault();
                searchUsers(userSearchInput.value);
            });
            userSearchInput.addEventListener("search", function () {
                if (userSearchInput.value.trim() === "" && currentSearch !== "") {
                    searchUsers("");
                }
            });
            userSearchInput.addEventListener("input", function () {
                if (userSearchInput.value.trim() === "" && currentSearch !== "") {
                    searchUsers("");
                }
            });
        }

        if (userRoleSelect instanceof HTMLSelectElement) {
            userRoleSelect.addEventListener("change", function () {
                filterUsers();
            });
        }

        if (userStatusSelect instanceof HTMLSelectElement) {
            userStatusSelect.addEventListener("change", function () {
                filterUsers();
            });
        }

        setSortButtonState();

        document.addEventListener("change", function (event) {
            const checkbox = event.target;
            if (!(checkbox instanceof HTMLInputElement) || !checkbox.classList.contains("js-user-active")) {
                return;
            }

            const userId = checkbox.dataset.userId;
            if (!userId) {
                return;
            }

            if (!confirmModal || !confirmMessageElement || !confirmButton) {
                submitUserActiveChange(checkbox, userId);
                return;
            }

            const previousChecked = !checkbox.checked;
            const actionText = checkbox.checked ? "activate" : "deactivate";
            const userName = checkbox.dataset.userName || "this user";
            confirmMessageElement.textContent = `Are you sure you want to ${actionText} ${userName}?`;
            pendingChange = { checkbox, userId, previousChecked };
            confirmModal.show();
        });

        if (confirmModalElement) {
            confirmModalElement.addEventListener("hidden.bs.modal", function () {
                if (!pendingChange) {
                    return;
                }

                pendingChange.checkbox.checked = pendingChange.previousChecked;
                pendingChange = null;
            });
        }

        if (confirmButton) {
            confirmButton.addEventListener("click", async function () {
                if (!pendingChange) {
                    return;
                }

                const currentChange = pendingChange;
                pendingChange = null;
                confirmModal.hide();
                await submitUserActiveChange(currentChange.checkbox, currentChange.userId);
            });
        }
    });
</script>
