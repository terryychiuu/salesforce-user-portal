@model IReadOnlyList<SalesforceManager.Models.SalesforceUserDto>
@{
    ViewData["Title"] = "Home Page";
}


<h2>Salesforce Users</h2>
@if (!string.IsNullOrWhiteSpace(ViewBag.ErrorMessage))
{
    <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
}

@if (Model == null || Model.Count == 0)
{
    <p>No users found.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Username</th>
                <th>Last Login</th>
                <th>Role</th>
                <th>Active</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Name</td>
                <td>@user.Username</td>
                <td>@user.LastLoginDate</td>
                <td>@user.UserRoleId</td>
                <td>
                    <input
                        type="checkbox"
                        class="js-user-active"
                        data-user-id="@user.Id"
                        data-user-name="@user.Name"
                        @(user.IsActive ? "checked" : "") />
                </td>
            </tr>
        }
        </tbody>
    </table>
}

<div class="modal fade" id="userActiveConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm status change</h5>
            </div>
            <div class="modal-body">
                <p id="userActiveConfirmMessage" class="mb-0"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmUserActiveChangeBtn">Confirm</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="userActiveErrorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Update failed</h5>
            </div>
            <div class="modal-body">
                <p id="userActiveErrorMessage" class="mb-0"></p>
                <p id="userActiveErrorDetail" 
                    class="mb-0" 
                    style="
                        font-family:Consolas,'Courier New',monospace;
                        font-size:10px;
                        white-space:pre-wrap;
                        padding:8px;
                        margin-top:8px;
                        margin-bottom:0;
                        border-radius:4px;
                        ">
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const confirmModalElement = document.getElementById("userActiveConfirmModal");
        const confirmMessageElement = document.getElementById("userActiveConfirmMessage");
        const confirmButton = document.getElementById("confirmUserActiveChangeBtn");
        const errorModalElement = document.getElementById("userActiveErrorModal");
        const errorMessageElement = document.getElementById("userActiveErrorMessage");
        const errorDetailElement = document.getElementById("userActiveErrorDetail");
        const canUseBootstrapModal = typeof window.bootstrap !== "undefined" && confirmModalElement;
        const confirmModal = canUseBootstrapModal ? new window.bootstrap.Modal(confirmModalElement) : null;
        const errorModal = canUseBootstrapModal && errorModalElement ? new window.bootstrap.Modal(errorModalElement) : null;
        let pendingChange = null;


        async function submitUserActiveChange(checkbox, userId) {
            const previousChecked = !checkbox.checked;
            checkbox.disabled = true;

            try {
                const response = await fetch(`/api/sf/users/${encodeURIComponent(userId)}/active`, {
                    method: "PATCH",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({
                        inactive: !checkbox.checked
                    })
                });

                if (!response.ok) {
                    const text = await response.text();
                    const errorBody = JSON.parse(text);
                    throw new Error(errorBody.detail);
                }
            } catch (error) {
                checkbox.checked = previousChecked;
                const message = `Unable to ${previousChecked ? "activate" : "deactivate"} user`;
                errorMessageElement.textContent = message;
                errorDetailElement.textContent = error.message;
                errorModal.show();
            } finally {
                checkbox.disabled = false;
            }
        }

        document.addEventListener("change", function (event) {
            const checkbox = event.target;
            if (!(checkbox instanceof HTMLInputElement) || !checkbox.classList.contains("js-user-active")) {
                return;
            }

            const userId = checkbox.dataset.userId;
            if (!userId) {
                return;
            }

            if (!confirmModal || !confirmMessageElement || !confirmButton) {
                submitUserActiveChange(checkbox, userId);
                return;
            }

            const previousChecked = !checkbox.checked;
            const actionText = checkbox.checked ? "activate" : "deactivate";
            const userName = checkbox.dataset.userName || "this user";
            confirmMessageElement.textContent = `Are you sure you want to ${actionText} ${userName}?`;
            pendingChange = { checkbox, userId, previousChecked };
            confirmModal.show();
        });

        if (confirmModalElement) {
            confirmModalElement.addEventListener("hidden.bs.modal", function () {
                if (!pendingChange) {
                    return;
                }

                pendingChange.checkbox.checked = pendingChange.previousChecked;
                pendingChange = null;
            });
        }

        if (confirmButton) {
            confirmButton.addEventListener("click", async function () {
                if (!pendingChange) {
                    return;
                }

                const currentChange = pendingChange;
                pendingChange = null;
                confirmModal.hide();
                await submitUserActiveChange(currentChange.checkbox, currentChange.userId);
            });
        }
    });
</script>
